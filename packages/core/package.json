{
  "name": "@sdk-forge/core",
  "version": "0.0.1",
  "description": "OpenAPI spec loading, normalization, and IR — the shared foundation for sdk-forge generators",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sdk-forge/sdk-forge.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sdk-forge/sdk-forge#readme",
  "bugs": {
    "url": "https://github.com/sdk-forge/sdk-forge/issues"
  },
  "keywords": [
    "openapi",
    "sdk",
    "codegen",
    "generator",
    "sdk-forge"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "openapi-types": "^12.1.3",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.5.0"
  }
}
