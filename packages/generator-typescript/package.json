{
  "name": "@sdk-forge/generator-typescript",
  "version": "0.0.1",
  "description": "TypeScript SDK generator for sdk-forge — produces idiomatic, zero-dependency TypeScript clients from OpenAPI specs",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sdk-forge/sdk-forge.git",
    "directory": "packages/generator-typescript"
  },
  "homepage": "https://github.com/sdk-forge/sdk-forge#readme",
  "bugs": {
    "url": "https://github.com/sdk-forge/sdk-forge/issues"
  },
  "keywords": [
    "openapi",
    "sdk",
    "codegen",
    "generator",
    "typescript",
    "sdk-forge"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sdk-forge/core": "workspace:*",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
